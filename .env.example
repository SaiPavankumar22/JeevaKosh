# ── MongoDB ───────────────────────────────────────────────────────────────────
MONGODB_URI=mongodb://localhost:27017
DB_NAME=jeevakosha

# ── Auth ─────────────────────────────────────────────────────────────────────
# Generate a strong random string: python -c "import secrets; print(secrets.token_hex(32))"
JWT_SECRET=CHANGE_ME_before_production

# ── Nebius — OCR, chat LLM, embeddings ───────────────────────────────────────
NEBIUS_API_KEY=your_nebius_api_key_here

# ── AI Diagnosis — Sarvam (speech-to-text / text-to-speech) ───────────────────
SARVAM_API_KEY=your_sarvam_api_key_here

# ── AI Diagnosis — MedGemma via HuggingFace ───────────────────────────────────
HF_INFERENCE_ENDPOINT=https://your-endpoint.huggingface.cloud/v1
HF_API_TOKEN=your_huggingface_token_here
HF_MODEL=google/medgemma-1.5-4b-it

# ── Portfolio sharing — Supabase Storage ─────────────────────────────────────
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_KEY=your_supabase_service_role_key

# ── Deployment URLs (no trailing slash) ───────────────────────────────────────
# Render backend URL, e.g. https://jeevakosha-api.onrender.com
BACKEND_BASE_URL=http://localhost:8000
# Vercel frontend URL, e.g. https://jeevakosha.vercel.app
FRONTEND_URL=http://localhost:5173
